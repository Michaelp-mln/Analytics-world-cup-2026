# ======================================================================
# Variáveis de PRODUÇÃO (no servidor). Copie para `.env`:  cp .env.prod.example .env
# NÃO comite o .env (já está no .gitignore).
# ======================================================================

# Imagem publicada no GHCR pelo GitHub Actions — em MINÚSCULAS.
# Ex.: ghcr.io/michaelprimo/analytic-system
IMAGE=ghcr.io/SEU_USUARIO/SEU_REPO

# Domínio para HTTPS automático. Deixe ":80" para acessar via IP (sem TLS).
# Ex.: DOMAIN=copa2026.seudominio.com
DOMAIN=:80

# Senha do Postgres — troque por algo forte.
POSTGRES_PASSWORD=troque-esta-senha-por-uma-forte

# --- Aplicação ---
INGESTION_SOURCE=simulator
SIM_MODE=manual
MONTE_CARLO_RUNS=10000

# (Opcional) dados reais — só funciona com plano pago da API-Football p/ 2026.
API_FOOTBALL_KEY=
API_FOOTBALL_SEASON=2026

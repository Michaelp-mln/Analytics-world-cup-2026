# ======================================================================
# WC 2026 Analytics — configuração de ambiente
# Copie para `.env` (cp .env.example .env) e ajuste os valores.
# O docker-compose carrega este arquivo automaticamente.
# ======================================================================

# Fonte de dados de ingestão: "api" (API-Football, real) ou "simulator" (sintético).
# Se "api" for escolhido mas API_FOOTBALL_KEY estiver vazio, o sistema
# cai automaticamente no simulador (com aviso no log).
INGESTION_SOURCE=api

# Controle do simulador: "manual" (cada rodada por clique no dashboard,
# inclusive o mata-mata) ou "auto" (joga sozinho em tempo comprimido).
SIM_MODE=manual

# --- API-Football (https://www.api-football.com/) ---
# Crie uma conta gratuita e cole a chave aqui para consumir dados reais.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Intervalo (segundos) entre as varreduras de partidas ao vivo na API.
POLL_INTERVAL_SECONDS=20

# --- Simulador ---
# Segundos de "tempo real" por minuto simulado de jogo (compressão temporal).
SIM_SECONDS_PER_MINUTE=0.4

# --- Monte Carlo (probabilidade de classificação) ---
MONTE_CARLO_RUNS=10000

# --- Infra (valores default já apontam para os serviços do compose) ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_EVENTS=match.events
POSTGRES_DSN=postgresql://wc2026:wc2026@postgres:5432/wc2026
